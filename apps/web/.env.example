# Docs site URL — controls "See all FAQs" and footer "Docs" link visibility
# Local: http://localhost:3001 (set in .env.local)
# Production: set your docs URL in Vercel env vars
NEXT_PUBLIC_DOCS_URL=

# Mintlify rewrite destination (server-side only)
# Defaults to https://hubble-cc00cf1e.mintlify.dev/docs
# Note: local proxy (http://localhost:3001) breaks Mintlify styling due to /_next/ path conflicts
MINTLIFY_BASE_URL=
