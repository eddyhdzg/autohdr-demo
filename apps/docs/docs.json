{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "appearance": {
    "default": "system",
    "strict": false
  },
  "name": "AutoHDR",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "/"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#404040",
    "light": "#D4D4D4",
    "dark": "#171717"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Back to App",
      "href": "https://autohdr.vercel.app/"
    }
  },
  "navigation": {
    "languages": [
      {
        "language": "en",
        "tabs": [
          {
            "tab": "Guides",
            "icon": "book-open",
            "groups": [
              {
                "group": "Welcome",
                "pages": ["index", "quickstart"]
              },
              {
                "group": "Getting Started",
                "icon": "rocket",
                "pages": [
                  "getting-started/create-account",
                  "getting-started/upload-photos",
                  "getting-started/download-results"
                ]
              },
              {
                "group": "Pricing",
                "icon": "credit-card",
                "pages": ["pricing"]
              },
              {
                "group": "Account",
                "icon": "gear",
                "pages": ["account/settings", "account/billing"]
              },
              {
                "group": "Help",
                "icon": "circle-question",
                "pages": ["faq", "support"]
              }
            ]
          },
          {
            "tab": "Features",
            "icon": "wand-magic-sparkles",
            "groups": [
              {
                "group": "Editing Services",
                "pages": [
                  "features/hdr-editing",
                  "features/flambient-editing",
                  "features/day-to-dusk",
                  "features/grass-greening",
                  "features/object-removal",
                  "features/virtual-staging",
                  "features/tv-blackout"
                ]
              }
            ]
          },
          {
            "tab": "Integrations",
            "icon": "puzzle-piece",
            "groups": [
              {
                "group": "Integrations",
                "pages": [
                  "integrations/overview",
                  "integrations/spiro",
                  "integrations/hd-photohub",
                  "integrations/tonomo",
                  "integrations/aryeo",
                  "integrations/dropbox"
                ]
              }
            ]
          }
        ]
      },
      {
        "language": "es",
        "tabs": [
          {
            "tab": "Guías",
            "icon": "book-open",
            "groups": [
              {
                "group": "Bienvenida",
                "pages": ["es/index", "es/quickstart"]
              },
              {
                "group": "Primeros Pasos",
                "icon": "rocket",
                "pages": [
                  "es/getting-started/create-account",
                  "es/getting-started/upload-photos",
                  "es/getting-started/download-results"
                ]
              },
              {
                "group": "Precios",
                "icon": "credit-card",
                "pages": ["es/pricing"]
              },
              {
                "group": "Cuenta",
                "icon": "gear",
                "pages": ["es/account/settings", "es/account/billing"]
              },
              {
                "group": "Ayuda",
                "icon": "circle-question",
                "pages": ["es/faq", "es/support"]
              }
            ]
          },
          {
            "tab": "Funciones",
            "icon": "wand-magic-sparkles",
            "groups": [
              {
                "group": "Servicios de Edición",
                "pages": [
                  "es/features/hdr-editing",
                  "es/features/flambient-editing",
                  "es/features/day-to-dusk",
                  "es/features/grass-greening",
                  "es/features/object-removal",
                  "es/features/virtual-staging",
                  "es/features/tv-blackout"
                ]
              }
            ]
          },
          {
            "tab": "Integraciones",
            "icon": "puzzle-piece",
            "groups": [
              {
                "group": "Integraciones",
                "pages": [
                  "es/integrations/overview",
                  "es/integrations/spiro",
                  "es/integrations/hd-photohub",
                  "es/integrations/tonomo",
                  "es/integrations/aryeo",
                  "es/integrations/dropbox"
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "instagram": "https://www.instagram.com/auto.hdr/",
      "linkedin": "https://www.linkedin.com/company/autohdr/"
    }
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true
  },
  "search": {
    "prompt": "Search AutoHDR docs..."
  }
}
